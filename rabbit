// ── STATE ──────────────────────────────────────────────────
let owned = JSON.parse(localStorage.getItem('wc26_owned') || '{}');
let filterMode = 'all';
let searchTerm = '';

// ── HELPERS ────────────────────────────────────────────────
function isOwned(code) {
  if (owned[code] !== undefined) return owned[code];
  // Default: if marked missing in scan, not owned; else owned
  const s = ALBUM.find(x => x.code === code);
  return s ? !s.missing : false;
}

function toggleOwned(code) {
  owned[code] = !isOwned(code);
  localStorage.setItem('wc26_owned', JSON.stringify(owned));
  updateStats();
  renderAll();
}

function updateStats() {
  const total = ALBUM.length;
  const haveCount = ALBUM.filter(s => isOwned(s.code)).length;
  const missingCount = total - haveCount;
  const pct = Math.round((haveCount / total) * 100);
  document.getElementById('stat-have').textContent = haveCount;
  document.getElementById('stat-missing').textContent = missingCount;
  document.getElementById('stat-pct').textContent = pct + '%';
  document.getElementById('progress-bar').style.width = pct + '%';
}

function setFilter(mode, btn) {
  filterMode = mode;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAll();
}

function filterAll() {
  searchTerm = document.getElementById('search').value.toLowerCase();
  renderAll();
}

function scrollToGroup(g) {
  if (!g) return;
  const el = document.getElementById('group-' + g);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetAll() {
  if (!confirm('Reset all stickers to their original scanned state?')) return;
  owned = {};
  localStorage.setItem('wc26_owned', JSON.stringify(owned));
  updateStats();
  renderAll();
}

// ── RENDER ─────────────────────────────────────────────────
const GROUP_NAMES = {
  A:'Group A', B:'Group B', C:'Group C', D:'Group D',
  E:'Group E', F:'Group F', G:'Group G', H:'Group H',
  I:'Group I', J:'Group J', K:'Group K', L:'Group L',
  HISTORY:'FIFA World Cup History', COCA:'Coca-Cola Special Edition'
};

function renderAll() {
  const main = document.getElementById('main-content');
  const groups = [...new Set(ALBUM.map(s => s.group))];

  let html = '';
  for (const group of groups) {
    const stickers = ALBUM.filter(s => s.group === group);
    const teams = [...new Set(stickers.map(s => s.team))];

    let groupHtml = '';
    for (const team of teams) {
      const ts = stickers.filter(s => s.team === team);
      let chips = '';
      let anyVisible = false;

      for (const s of ts) {
        const owned_ = isOwned(s.code);
        const missing_ = !owned_;
        if (filterMode === 'missing' && owned_) continue;
        if (filterMode === 'have' && missing_) continue;
        if (searchTerm && !s.team.toLowerCase().includes(searchTerm) &&
            !s.code.toLowerCase().includes(searchTerm) &&
            !s.name.toLowerCase().includes(searchTerm)) continue;
        anyVisible = true;
        const cls = owned_ ? 'have' : 'missing';
        chips += `<div class="sticker-chip ${cls}" onclick="toggleOwned('${s.code}')">
          <span class="code">${s.code}</span>
          <span class="name-label">${s.name}</span>
        </div>`;
      }

      if (!anyVisible) continue;
      const haveT = ts.filter(s => isOwned(s.code)).length;
      const allDone = haveT === ts.length;
      groupHtml += `<div class="team-card${allDone?' complete':''}">
        <div class="team-header">
          <span class="team-flag">${ts[0].flag}</span>
          <span class="team-name">${team}</span>
          <span class="team-count${allDone?' done':''}">
            ${haveT}/${ts.length}${allDone?' ✓':''}
          </span>
        </div>
        <div class="stickers-list">${chips}</div>
      </div>`;
    }

    if (!groupHtml) continue;

    const gStickers = stickers.filter(s => {
      if (filterMode === 'missing' && isOwned(s.code)) return false;
      if (filterMode === 'have' && !isOwned(s.code)) return false;
      if (searchTerm && !s.team.toLowerCase().includes(searchTerm) &&
          !s.code.toLowerCase().includes(searchTerm) &&
          !s.name.toLowerCase().includes(searchTerm)) return false;
      return true;
    });
    if (!gStickers.length) continue;

    const gHave = stickers.filter(s => isOwned(s.code)).length;
    html += `<div class="group-section" id="group-${group}">
      <div class="group-header">
        <span class="group-badge">${group}</span>
        <span class="group-name">${GROUP_NAMES[group]}</span>
        <span class="group-progress"><span>${gHave}</span>/${stickers.length}</span>
      </div>
      <div class="teams-grid">${groupHtml}</div>
    </div>`;
  }

  main.innerHTML = html || '<div class="empty-state">No stickers match your search. Try a different filter.</div>';
}

// init
updateStats();
renderAll();
