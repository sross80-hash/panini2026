<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panini FIFA World Cup 2026 – Sticker Tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap');

  :root {
    --bg: #0d0f14;
    --surface: #161920;
    --card: #1e2230;
    --border: #2a2f40;
    --accent: #e8c53a;
    --accent2: #e84c3a;
    --green: #3ae87f;
    --text: #e8ecf0;
    --muted: #7a8294;
    --radius: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: linear-gradient(135deg, #1a1060 0%, #0d0f14 60%);
    border-bottom: 2px solid var(--accent);
    padding: 20px 24px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-left { display: flex; align-items: center; gap: 14px; }

  .trophy { font-size: 36px; }

  .header-title h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--accent);
    line-height: 1;
  }
  .header-title p {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .header-stats {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .stat-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 6px 16px;
    text-align: center;
  }
  .stat-pill .val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    line-height: 1;
  }
  .stat-pill .lbl {
    font-size: 9px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .val.missing { color: var(--accent2); }
  .val.have { color: var(--green); }
  .val.pct { color: var(--accent); }

  /* PROGRESS BAR */
  .progress-bar-wrap {
    width: 100%;
    background: var(--card);
    height: 6px;
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--green));
    transition: width 0.4s ease;
    border-radius: 3px;
  }

  /* CONTROLS */
  .controls {
    padding: 16px 24px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .search-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 14px;
    color: var(--text);
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    width: 220px;
    outline: none;
  }
  .search-box:focus { border-color: var(--accent); }
  .search-box::placeholder { color: var(--muted); }

  .filter-btn {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 14px;
    color: var(--text);
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 700; }

  .group-select {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 14px;
    color: var(--text);
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    outline: none;
  }
  .group-select:focus { border-color: var(--accent); }

  .btn-mark-all {
    background: var(--accent2);
    border: none;
    border-radius: var(--radius);
    padding: 8px 16px;
    color: #fff;
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    cursor: pointer;
    margin-left: auto;
  }
  .btn-mark-all:hover { opacity: 0.85; }

  /* ERRORS BANNER */
  .errors-banner {
    margin: 16px 24px;
    background: #2a1515;
    border: 1px solid var(--accent2);
    border-radius: var(--radius);
    padding: 14px 18px;
  }
  .errors-banner h3 {
    color: var(--accent2);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .error-item {
    font-size: 12px;
    color: #e8b4b4;
    padding: 3px 0;
    border-bottom: 1px solid #3a2020;
  }
  .error-item:last-child { border-bottom: none; }
  .error-item strong { color: var(--accent2); }

  /* MAIN */
  main { padding: 16px 24px 40px; }

  .group-section { margin-bottom: 32px; }

  .group-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border);
  }
  .group-badge {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    background: var(--accent);
    color: #000;
    padding: 2px 10px;
    border-radius: 4px;
    letter-spacing: 1px;
  }
  .group-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    color: var(--text);
  }
  .group-progress {
    margin-left: auto;
    font-size: 11px;
    color: var(--muted);
  }
  .group-progress span { color: var(--accent); font-weight: 700; }

  /* TEAM CARD */
  .teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }

  .team-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .team-card.complete { border-color: var(--green); }
  .team-card:hover { border-color: var(--accent); }

  .team-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .team-flag { font-size: 22px; }
  .team-name {
    font-weight: 700;
    font-size: 13px;
    flex: 1;
  }
  .team-count {
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }
  .team-count.done { color: var(--green); }

  .stickers-list {
    padding: 10px 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .sticker-chip {
    display: flex;
    align-items: center;
    gap: 5px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 8px;
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
    font-size: 11px;
    color: var(--text);
  }
  .sticker-chip:hover { border-color: var(--accent); }
  .sticker-chip.have {
    background: #0d2b1a;
    border-color: var(--green);
    color: var(--green);
    text-decoration: line-through;
    opacity: 0.7;
  }
  .sticker-chip.missing {
    border-color: var(--accent2);
    color: #f4a0a0;
  }
  .sticker-chip .code {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.5px;
  }
  .sticker-chip .name-label {
    font-size: 10px;
    color: var(--muted);
    max-width: 100px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .sticker-chip.have .name-label { color: #4a7a5a; }

  /* HISTORY SECTION */
  .history-section {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    margin-bottom: 12px;
  }
  .history-section h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    margin-bottom: 10px;
    color: var(--accent);
  }
  .history-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* COLA PAGE */
  .cola-section {
    background: #1a0808;
    border: 1px solid #8b1a1a;
    border-radius: var(--radius);
    padding: 14px 18px;
    margin-bottom: 12px;
  }
  .cola-section h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    margin-bottom: 10px;
    color: #e84c3a;
  }

  /* HIDDEN */
  .hidden { display: none !important; }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 40px;
    color: var(--muted);
    font-size: 14px;
  }

  footer {
    text-align: center;
    padding: 20px;
    color: var(--muted);
    font-size: 11px;
    border-top: 1px solid var(--border);
  }
</style>
</head>
