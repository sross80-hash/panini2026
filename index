  { group:'COCA', team:'Coca-Cola Special Edition', flag:'🥤', code:'CC11', name:'CC11', status:'missing' },
  { group:'COCA', team:'Coca-Cola Special Edition', flag:'🥤', code:'CC12', name:'Gabriel Magalhães', status:'missing' },
];

// Build stable id and load saved overrides
ALBUM.forEach((s, i) => s.id = s.code + '|' + s.team);
let saved = JSON.parse(localStorage.getItem('wc26_v2') || '{}');
ALBUM.forEach(s => { if (saved[s.id]) s.status = saved[s.id]; });

let filterMode = 'all';
let searchTerm = '';

const GROUP_NAMES = {
  EXTRA:'Host Countries & Emblems',
  A:'Group A', B:'Group B', C:'Group C', D:'Group D', E:'Group E', F:'Group F',
  G:'Group G', H:'Group H', I:'Group I', J:'Group J', K:'Group K', L:'Group L',
  HISTORY:'FIFA World Cup History', COCA:'Coca-Cola Special Edition'
};

function save() { 
  const o = {}; ALBUM.forEach(s => o[s.id] = s.status);
  localStorage.setItem('wc26_v2', JSON.stringify(o));
}

// cycle: missing -> have -> secondary -> replace -> missing
function cycle(id) {
  const s = ALBUM.find(x => x.id === id);
  const order = ['missing','have','secondary','replace'];
  s.status = order[(order.indexOf(s.status) + 1) % order.length];
  save(); updateStats(); renderAll();
}

function updateStats() {
  // 'rest' rows count as 1 line but represent the bulk; for headline numbers we
  // count individual tracked lines. Real-sticker total is ~681 but we track key items + rest groups.
  const tracked = ALBUM.filter(s => !s.code.endsWith('rest'));
  const have = tracked.filter(s => s.status === 'have').length;
  const missing = tracked.filter(s => s.status === 'missing' || s.status === 'replace').length;
  const flag = tracked.filter(s => s.status === 'secondary').length;
  // Completion based on the full album (approx 681 stickers); rest-rows are complete teams' filler
  const restHave = ALBUM.filter(s => s.code.endsWith('rest')).length;
  const totalForPct = tracked.length;
  const pct = Math.round((have / totalForPct) * 100);
  document.getElementById('stat-have').textContent = have;
  document.getElementById('stat-missing').textContent = missing;
  document.getElementById('stat-flag').textContent = flag;
  document.getElementById('stat-pct').textContent = pct + '%';
  document.getElementById('progress-bar').style.width = pct + '%';
}

function setFilter(mode, btn) {
  filterMode = mode;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active'); renderAll();
}
function filterAll() { searchTerm = document.getElementById('search').value.toLowerCase(); renderAll(); }
function scrollToGroup(g) {
  if (!g) return;
  const id = g === 'summary' ? 'summary-block' : 'group-' + g;
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function resetAll() {
  if (!confirm('Reset all stickers to the last scanned state (18 June)?')) return;
  localStorage.removeItem('wc26_v2'); location.reload();
}
function toggleCollapse(el) { el.closest('.summary-section').classList.toggle('collapsed'); }

function statusClass(st) {
  return st === 'have' ? 'have' : st === 'secondary' ? 'secondary' : st === 'replace' ? 'replace' : 'missing';
}
function passesFilter(s) {
  if (filterMode === 'missing' && !(s.status === 'missing' || s.status === 'replace')) return false;
  if (filterMode === 'have' && s.status !== 'have') return false;
  if (filterMode === 'special' && !(s.status === 'secondary' || s.status === 'replace')) return false;
  if (searchTerm) {
    const hay = (s.team + ' ' + s.code + ' ' + s.name).toLowerCase();
    if (!hay.includes(searchTerm)) return false;
  }
  return true;
}

function chip(s) {
  const cls = statusClass(s.status);
  const foilMark = s.foil ? ' foil-marker' : '';
  let tag = '';
  if (s.status === 'secondary') tag = '<span class="tag sec">2nd book</span>';
  if (s.status === 'replace') tag = '<span class="tag rep">replace</span>';
  return `<div class="sticker-chip ${cls}${foilMark}" onclick="cycle('${s.id}')" title="Tap to change status">
    <span class="code">${s.code}</span>
    <span class="name-label">${s.name}</span>${tag}
  </div>`;
}

function renderSummary() {
  // Foil needed (missing or replace, foil:true)
  const foilNeed = ALBUM.filter(s => s.foil && (s.status === 'missing' || s.status === 'replace'));
  const photoNeed = ALBUM.filter(s => s.photo && (s.status === 'missing' || s.status === 'replace'));
  const replaceNeed = ALBUM.filter(s => s.status === 'replace');
  const secondary = ALBUM.filter(s => s.status === 'secondary');

  // Completed teams: every tracked sticker for that team is 'have' (rest counts as have)
  const teams = [...new Set(ALBUM.filter(s => !['HISTORY','COCA','EXTRA'].includes(s.group)).map(s => s.team))];
  const done = [];
  teams.forEach(t => {
    const ts = ALBUM.filter(s => s.team === t);
    if (ts.every(s => s.status === 'have')) done.push(ts[0]);
  });

  const miniChip = (s, doneStyle) =>
    `<div class="mini-chip${doneStyle?' done-chip':''}"><span class="flag">${s.flag}</span><span class="code">${s.code||s.team}</span> <span style="color:var(--muted)">${doneStyle? s.team : s.name}</span></div>`;

  let html = '<div id="summary-block">';

  // Completed teams
  html += `<div class="summary-section sec-done">
    <h3 class="collapse-toggle" onclick="toggleCollapse(this)"><span class="arrow">▾</span> 🎉 Completed teams — yay us! <span class="count-badge">${done.length}</span></h3>
    <div class="summary-body">
      ${done.length ? '<div class="chip-row">' + done.map(s => miniChip(s, true)).join('') + '</div>'
        : '<div class="info-line">No fully-complete teams yet — keep going!</div>'}
    </div></div>`;

  // Foil / shiny needed
  html += `<div class="summary-section sec-foil">
    <h3 class="collapse-toggle" onclick="toggleCollapse(this)"><span class="arrow">▾</span> ✦ Shiny / foil stickers still needed <span class="count-badge">${foilNeed.length}</span></h3>
    <div class="summary-body">
      <div class="info-line">The glittery badge & emblem stickers — quick to spot what's outstanding.</div>
      ${foilNeed.length ? '<div class="chip-row">' + foilNeed.map(s => miniChip(s)).join('') + '</div>'
        : '<div class="info-line">All foils collected. 🎉</div>'}
    </div></div>`;

  // Team photos needed
  html += `<div class="summary-section sec-photo">
    <h3 class="collapse-toggle" onclick="toggleCollapse(this)"><span class="arrow">▾</span> 📷 Team photos still needed <span class="count-badge">${photoNeed.length}</span></h3>
    <div class="summary-body">
      ${photoNeed.length ? '<div class="chip-row">' + photoNeed.map(s => miniChip(s)).join('') + '</div>'
        : '<div class="info-line">All team photos collected. 🎉</div>'}
    </div></div>`;

  // Needs replacement
  html += `<div class="summary-section sec-replace">
    <h3 class="collapse-toggle" onclick="toggleCollapse(this)"><span class="arrow">▾</span> ⚠️ Needs replacement <span class="count-badge">${replaceNeed.length}</span></h3>
    <div class="summary-body">
      <div class="info-line">Placed but wrong/damaged — treat these as still-needed.</div>
      ${replaceNeed.length ? '<div class="chip-row">' + replaceNeed.map(s => miniChip(s)).join('') + '</div>'
        : '<div class="info-line">Nothing to replace.</div>'}
    </div></div>`;

  // Secondary book
  html += `<div class="summary-section sec-secondary">
    <h3 class="collapse-toggle" onclick="toggleCollapse(this)"><span class="arrow">▾</span> ✏️ Have in 2nd book (pencil-marked) <span class="count-badge">${secondary.length}</span></h3>
    <div class="summary-body">
      <div class="info-line">Owned but living in the secondary book — not counted as placed, just tracked.</div>
      ${secondary.length ? '<div class="chip-row">' + secondary.map(s => miniChip(s)).join('') + '</div>'
        : '<div class="info-line">None flagged.</div>'}
    </div></div>`;

  html += '</div>';
  return html;
}

function renderGroups() {
  const groups = [...new Set(ALBUM.map(s => s.group))];
  let html = '';
  for (const group of groups) {
    const stickers = ALBUM.filter(s => s.group === group);
    const teams = [...new Set(stickers.map(s => s.team))];
    let groupHtml = '';

    for (const team of teams) {
      const ts = stickers.filter(s => s.team === team);
      const visible = ts.filter(passesFilter);
      if (!visible.length) continue;
      const allDone = ts.every(s => s.status === 'have');
      const haveCount = ts.filter(s => s.status === 'have').length;
      groupHtml += `<div class="team-card${allDone?' complete':''}">
        <div class="team-header">
          <span class="team-flag">${ts[0].flag}</span>
          <span class="team-name">${team}</span>
          <span class="team-count${allDone?' done':''}">${allDone ? 'Complete ✓' : haveCount+'/'+ts.length}</span>
        </div>
        <div class="stickers-list">${visible.map(chip).join('')}</div>
      </div>`;
    }
    if (!groupHtml) continue;
    const gHave = stickers.filter(s => s.status === 'have').length;
    html += `<div class="group-section" id="group-${group}">
      <div class="group-header">
        <span class="group-badge">${group === 'EXTRA' ? '★' : group === 'HISTORY' ? 'H' : group === 'COCA' ? 'CC' : group}</span>
        <span class="group-name">${GROUP_NAMES[group]}</span>
        <span class="group-progress"><span>${gHave}</span>/${stickers.length} lines</span>
      </div>
      <div class="teams-grid">${groupHtml}</div>
    </div>`;
  }
  return html || '<div class="empty-state">No stickers match your search/filter.</div>';
}

function renderAll() {
  document.getElementById('main-content').innerHTML = renderSummary() + renderGroups();
}

updateStats();
renderAll();
</script>
</body>
</html>
