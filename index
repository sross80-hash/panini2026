      <h1>Panini FIFA World Cup 2026</h1>
      <p>Sticker Collection Tracker · Updated 18 June 2026</p>
    </div>
  </div>
  <div class="header-stats">
    <div class="stat-pill"><div class="val have" id="stat-have">0</div><div class="lbl">Collected</div></div>
    <div class="stat-pill"><div class="val missing" id="stat-missing">0</div><div class="lbl">Still need</div></div>
    <div class="stat-pill"><div class="val flag" id="stat-flag">0</div><div class="lbl">In 2nd book</div></div>
    <div class="stat-pill"><div class="val pct" id="stat-pct">0%</div><div class="lbl">Complete</div></div>
  </div>
  <div style="width:100%; padding-top:4px;"><div class="progress-bar-wrap"><div class="progress-bar-fill" id="progress-bar" style="width:0%"></div></div></div>
</header>

<div class="controls">
  <input class="search-box" type="text" id="search" placeholder="🔍  Search team or sticker…" oninput="filterAll()">
  <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
  <button class="filter-btn" onclick="setFilter('missing', this)">Still need</button>
  <button class="filter-btn" onclick="setFilter('have', this)">Collected</button>
  <button class="filter-btn" onclick="setFilter('special', this)">Flags only</button>
  <select class="group-select" onchange="scrollToGroup(this.value)">
    <option value="">Jump to…</option>
    <option value="summary">Summary sections</option>
    <option value="A">Group A</option><option value="B">Group B</option>
    <option value="C">Group C</option><option value="D">Group D</option>
    <option value="E">Group E</option><option value="F">Group F</option>
    <option value="G">Group G</option><option value="H">Group H</option>
    <option value="I">Group I</option><option value="J">Group J</option>
    <option value="K">Group K</option><option value="L">Group L</option>
    <option value="EXTRA">Host / Emblems</option>
    <option value="HISTORY">History</option>
    <option value="COCA">Coca-Cola</option>
  </select>
  <button class="btn-reset" onclick="resetAll()">Reset all</button>
</div>

<div class="legend">
  <span><span class="dot have"></span> Collected</span>
  <span><span class="dot missing"></span> Still need</span>
  <span><span class="dot secondary"></span> Have in 2nd book (pencil mark)</span>
  <span><span class="dot replace"></span> Needs replacement</span>
  <span>✦ = foil / shiny</span>
</div>

<main id="main-content"></main>

<footer>Tap any sticker to cycle its status. Progress saves in this browser. Scanned from album photos · 18 June 2026</footer>

