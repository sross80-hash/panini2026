<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panini FIFA World Cup 2026 – Sticker Tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap');

  :root {
    --bg: #0d0f14;
    --surface: #161920;
    --card: #1e2230;
    --border: #2a2f40;
    --accent: #e8c53a;
    --accent2: #e84c3a;
    --green: #3ae87f;
    --purple: #a87fe8;
    --orange: #e8954c;
    --text: #e8ecf0;
    --muted: #7a8294;
    --radius: 10px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; }

  header {
    background: linear-gradient(135deg, #1a1060 0%, #0d0f14 60%);
    border-bottom: 2px solid var(--accent);
    padding: 20px 24px 16px; display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 12px;
    position: sticky; top: 0; z-index: 100;
  }
  .header-left { display: flex; align-items: center; gap: 14px; }
  .trophy { font-size: 36px; }
  .header-title h1 { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; color: var(--accent); line-height: 1; }
  .header-title p { font-size: 11px; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }
  .header-stats { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
  .stat-pill { background: var(--card); border: 1px solid var(--border); border-radius: 999px; padding: 6px 16px; text-align: center; }
  .stat-pill .val { font-family: 'Bebas Neue', sans-serif; font-size: 22px; line-height: 1; }
  .stat-pill .lbl { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
  .val.missing { color: var(--accent2); }
  .val.have { color: var(--green); }
  .val.pct { color: var(--accent); }
  .val.flag { color: var(--purple); }

  .progress-bar-wrap { width: 100%; background: var(--card); height: 6px; border-radius: 3px; overflow: hidden; }
  .progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--green)); transition: width 0.4s ease; border-radius: 3px; }

  .controls { padding: 16px 24px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center; background: var(--surface); border-bottom: 1px solid var(--border); }
  .search-box { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 14px; color: var(--text); font-size: 13px; font-family: 'Inter', sans-serif; width: 200px; outline: none; }
  .search-box:focus { border-color: var(--accent); }
  .search-box::placeholder { color: var(--muted); }
  .filter-btn { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 14px; color: var(--text); font-size: 12px; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 700; }
  .group-select { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 14px; color: var(--text); font-size: 12px; font-family: 'Inter', sans-serif; cursor: pointer; outline: none; }
  .btn-reset { background: var(--accent2); border: none; border-radius: var(--radius); padding: 8px 16px; color: #fff; font-size: 12px; font-weight: 600; cursor: pointer; margin-left: auto; }
  .btn-reset:hover { opacity: 0.85; }

  main { padding: 16px 24px 40px; }

  /* SUMMARY SECTIONS */
  .summary-section { margin-bottom: 16px; border-radius: var(--radius); padding: 14px 18px; }
  .summary-section h3 { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 1px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  .summary-section .count-badge { font-size: 11px; background: rgba(255,255,255,0.12); padding: 2px 8px; border-radius: 999px; font-family: 'Inter', sans-serif; }
  .sec-foil { background: linear-gradient(135deg, #1a1830 0%, #14121f 100%); border: 1px solid var(--purple); }
  .sec-foil h3 { color: var(--purple); }
  .sec-photo { background: linear-gradient(135deg, #1a2818 0%, #121f12 100%); border: 1px solid var(--green); }
  .sec-photo h3 { color: var(--green); }
  .sec-replace { background: #2a1515; border: 1px solid var(--accent2); }
  .sec-replace h3 { color: var(--accent2); }
  .sec-secondary { background: #1f1a2e; border: 1px solid var(--purple); }
  .sec-secondary h3 { color: var(--purple); }
  .sec-done { background: linear-gradient(135deg, #14241a 0%, #0f1f14 100%); border: 1px solid var(--green); }
  .sec-done h3 { color: var(--green); }

  .chip-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .mini-chip { display: inline-flex; align-items: center; gap: 5px; background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 4px 9px; font-size: 11px; }
  .mini-chip .flag { font-size: 14px; }
  .mini-chip .code { font-family: 'Bebas Neue', sans-serif; font-size: 13px; color: var(--accent); }
  .mini-chip.done-chip { border-color: var(--green); }
  .mini-chip.done-chip .code { color: var(--green); }
  .info-line { font-size: 11px; color: var(--muted); margin-bottom: 8px; }

  .collapse-toggle { cursor: pointer; user-select: none; }
  .collapse-toggle .arrow { transition: transform 0.2s; display: inline-block; }
  .collapsed .arrow { transform: rotate(-90deg); }
  .collapsed .summary-body { display: none; }

  /* GROUP / TEAM */
  .group-section { margin-bottom: 28px; }
  .group-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid var(--border); }
  .group-badge { font-family: 'Bebas Neue', sans-serif; font-size: 13px; background: var(--accent); color: #000; padding: 2px 10px; border-radius: 4px; letter-spacing: 1px; }
  .group-name { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; }
  .group-progress { margin-left: auto; font-size: 11px; color: var(--muted); }
  .group-progress span { color: var(--accent); font-weight: 700; }

  .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 12px; }
  .team-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color 0.2s; }
  .team-card.complete { border-color: var(--green); box-shadow: 0 0 0 1px var(--green) inset; }
  .team-card:hover { border-color: var(--accent); }
  .team-header { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: var(--surface); border-bottom: 1px solid var(--border); }
  .team-flag { font-size: 22px; }
  .team-name { font-weight: 700; font-size: 13px; flex: 1; }
  .team-count { font-size: 11px; color: var(--muted); white-space: nowrap; }
  .team-count.done { color: var(--green); font-weight: 700; }

  .stickers-list { padding: 10px 14px; display: flex; flex-wrap: wrap; gap: 6px; }
  .sticker-chip { display: flex; align-items: center; gap: 5px; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 4px 8px; cursor: pointer; transition: all 0.15s; user-select: none; font-size: 11px; position: relative; }
  .sticker-chip:hover { border-color: var(--accent); }
  .sticker-chip.have { background: #0d2b1a; border-color: var(--green); color: var(--green); opacity: 0.75; }
  .sticker-chip.have .name-label { color: #4a7a5a; }
  .sticker-chip.have .code { text-decoration: line-through; }
  .sticker-chip.missing { border-color: var(--accent2); color: #f4a0a0; }
  .sticker-chip.secondary { border-color: var(--purple); background: #1f1a2e; color: var(--purple); }
  .sticker-chip.replace { border-color: var(--orange); background: #2a2015; color: var(--orange); }
  .sticker-chip.foil-marker::after { content:'✦'; position:absolute; top:-5px; right:-3px; font-size:10px; color: var(--purple); }
  .sticker-chip .code { font-family: 'Bebas Neue', sans-serif; font-size: 13px; letter-spacing: 0.5px; }
  .sticker-chip .name-label { font-size: 10px; color: var(--muted); max-width: 110px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .sticker-chip .tag { font-size: 8px; text-transform: uppercase; letter-spacing: 0.5px; padding: 1px 4px; border-radius: 3px; margin-left: 2px; }
  .tag.sec { background: var(--purple); color: #000; }
  .tag.rep { background: var(--orange); color: #000; }

  .legend { display: flex; flex-wrap: wrap; gap: 14px; font-size: 11px; color: var(--muted); padding: 0 24px 12px; }
  .legend span { display: inline-flex; align-items: center; gap: 5px; }
  .legend .dot { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }
  .dot.have { background: var(--green); }
  .dot.missing { background: var(--accent2); }
  .dot.secondary { background: var(--purple); }
  .dot.replace { background: var(--orange); }

  .empty-state { text-align: center; padding: 40px; color: var(--muted); font-size: 14px; }
  footer { text-align: center; padding: 20px; color: var(--muted); font-size: 11px; border-top: 1px solid var(--border); }
  .hidden { display: none !important; }
</style>
